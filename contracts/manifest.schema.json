{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://freecad-mcp.local/contracts/manifest.schema.json",
  "title": "FreeCAD MCP Artifact Manifest",
  "type": "object",
  "required": ["version", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_name", "version", "producer_workstream", "created_at_utc", "input_hashes", "path"],
        "additionalProperties": false,
        "properties": {
          "artifact_name": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "producer_workstream": { "type": "string", "minLength": 1 },
          "created_at_utc": { "type": "string", "format": "date-time" },
          "input_hashes": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "path": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
