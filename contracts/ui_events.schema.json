{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://freecad-mcp.local/contracts/ui_events.schema.json",
  "title": "FreeCAD MCP UI Event",
  "type": "object",
  "required": ["event_id", "event_type", "entity_ref", "timestamp_utc"],
  "additionalProperties": false,
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": {
      "type": "string",
      "enum": ["parameter_selected", "rule_clicked", "viewer_focus"]
    },
    "entity_ref": { "type": "string", "minLength": 1 },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    }
  }
}
